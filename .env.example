# --- Backend ---
# Postgres
POSTGRES_USER=dealiq
POSTGRES_PASSWORD=dealiq
POSTGRES_DB=dealiq
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy URL (override pour CI/sqlite si besoin)
DATABASE_URL=postgresql+psycopg://dealiq:dealiq@localhost:5432/dealiq

# Redis — utilisé par le rate-limit distribué (RATE_LIMIT_BACKEND=redis)
REDIS_URL=redis://localhost:6379/0

# Rate limiting (anti brute-force auth, actif en production)
RATE_LIMIT_BACKEND=memory   # memory (mono-instance) | redis (multi-instance)
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_SECONDS=60

# Sécurité / JWT
SECRET_KEY=change-me-in-prod-please-use-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
ALGORITHM=HS256

# App
ENVIRONMENT=development
DEFAULT_LOCALE=fr
DEFAULT_CURRENCY=XOF
CORS_ORIGINS=http://localhost:5173

# IA / LLM (Anthropic) — accélérateur, mode mock par défaut (aucune clé requise)
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=

# E-mail (notifications/invitations) — mock par défaut (journalisé, aucun envoi).
# Passer EMAIL_PROVIDER=smtp + renseigner SMTP_* pour un envoi réel
# (Amazon SES SMTP, Resend, Mailgun, Gmail…).
EMAIL_PROVIDER=mock
EMAIL_FROM=noreply@dealiq.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Stockage documentaire — local (FS) par défaut ; STORAGE_PROVIDER=s3 pour un vrai
# bucket (AWS S3 / Scaleway / MinIO). Identifiants AWS via la chaîne standard
# (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / profil / rôle IAM).
STORAGE_PROVIDER=local
STORAGE_DIR=storage
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
S3_SSE=AES256
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
