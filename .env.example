# ── Copier en .env et adapter ───────────────────────────────────────────────
# Postgres
POSTGRES_USER=dealiq
POSTGRES_PASSWORD=dealiq
POSTGRES_DB=dealiq
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# URL complète utilisée par le backend (host = "db" dans docker-compose)
DATABASE_URL=postgresql+psycopg2://dealiq:dealiq@localhost:5432/dealiq

# Redis (workers Agent A — Phase 2)
REDIS_URL=redis://localhost:6379/0

# Sécurité / Auth
SECRET_KEY=change-me-in-prod-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Utilisateur analyste créé au seed (auth simple mono-analyste)
FIRST_USER_EMAIL=analyste@dealiq.ci
FIRST_USER_PASSWORD=changeme

# ── Sources d'enrichissement (Phase 2) ──────────────────────────────────────
# Aucune clé disponible pour l'instant -> mode mock par défaut.
ENRICHMENT_MODE=mock          # mock | live
X_BEARER_TOKEN=
CRUNCHBASE_API_KEY=
ANTHROPIC_API_KEY=
