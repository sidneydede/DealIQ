# --- Backend ---
# Postgres
POSTGRES_USER=dealiq
POSTGRES_PASSWORD=dealiq
POSTGRES_DB=dealiq
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy URL (override pour CI/sqlite si besoin)
DATABASE_URL=postgresql+psycopg://dealiq:dealiq@localhost:5432/dealiq

# Redis (worker/cache — Lot ultérieur)
REDIS_URL=redis://localhost:6379/0

# Sécurité / JWT
SECRET_KEY=change-me-in-prod-please-use-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
ALGORITHM=HS256

# App
ENVIRONMENT=development
DEFAULT_LOCALE=fr
DEFAULT_CURRENCY=XOF
CORS_ORIGINS=http://localhost:5173

# IA / LLM (Anthropic) — accélérateur, mode mock par défaut (aucune clé requise)
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=

# E-mail (notifications/invitations) — mock par défaut (journalisé, aucun envoi).
# Passer EMAIL_PROVIDER=smtp + renseigner SMTP_* pour un envoi réel
# (Amazon SES SMTP, Resend, Mailgun, Gmail…).
EMAIL_PROVIDER=mock
EMAIL_FROM=noreply@dealiq.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
